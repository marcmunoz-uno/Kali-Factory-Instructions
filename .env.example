# Kali Factory configuration
# Copy to .env and fill in. scripts/bootstrap-secrets.sh creates the token file.

# API
KALI_FACTORY_API_HOST=127.0.0.1
KALI_FACTORY_API_PORT=8081
KALI_FACTORY_LOG_LEVEL=info

# Bearer token — points at the file, NOT the token itself.
KALI_FACTORY_API_TOKEN_FILE=./.secrets/api_token

# Redis / queue
KALI_FACTORY_REDIS_URL=redis://localhost:6379/0

# Runtime image — must match an entry in policy.allowlist.ALLOWED_RUNTIME_IMAGES.
KALI_FACTORY_RUNTIME_IMAGE=kali-factory/recon:latest

# Tools manifest path (path inside the API/worker process, not the container)
KALI_FACTORY_TOOLS_MANIFEST=./runtimes/kali/tools.json
